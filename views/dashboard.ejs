<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <%- include('partials/theme-head') %>
  <link rel="stylesheet" href="/css/dauto-layout.css" />
</head>
<body class="dashboard-shell">
  <%
    const layoutView = (typeof layout !== 'undefined' && layout)
      ? layout
      : buildLayoutViewModel(record);
    const statusMap = (typeof competenciaStatusMap !== 'undefined' && competenciaStatusMap)
      ? competenciaStatusMap
      : buildCompetenciaStatusMap([record]);
  %>
  <a href="#dashboard-content" class="skip-link">Ir para o conteúdo principal</a>
  <div id="app-toast" class="app-toast" role="status" aria-live="polite" hidden></div>

  <div id="sidebar-overlay" class="sidebar-overlay"></div>
  <aside id="sidebar-drawer" class="sidebar-drawer" aria-hidden="true">
    <div class="sidebar-header">
      <div class="sidebar-header__title">
        <span class="sidebar-header__eyebrow">GRUPO DAUTO</span>
        <h2 class="sidebar-header__main">Impostos da Folha</h2>
      </div>
      <button id="sidebar-close-btn" class="sidebar-close-btn" aria-label="Fechar menu">
        ✕
      </button>
    </div>
    <nav class="sidebar-nav" aria-label="Navegação por competências">
      <% sidebarYears.forEach(year => { %>
        <% const meses = buildCompetenciaList(year); %>
        <details class="sidebar-nav-year" <%= year === currentYear ? 'open' : '' %>>
          <summary><%= year %></summary>
          <div class="sidebar-nav-months">
            <% meses.forEach(mes => { %>
              <% const st = competenciaStatusMap[mes] || { status: 'rascunho', statusLabel: 'Rascunho' }; %>
              <a href="/dashboard/<%= helpers.toCompetenciaSlug(mes) %>"
                 class="sidebar-nav-month <%= mes === record.competencia ? 'sidebar-nav-month--active' : '' %>">
                <span><%= mes %></span>
                <span class="status-badge status-badge--<%= st.status %>"><%= st.statusLabel %></span>
              </a>
            <% }) %>
          </div>
        </details>
      <% }) %>
    </nav>
  </aside>

  <div class="dashboard-shell__main">
    <div class="app">
      <%- include('partials/header') %>
      <%- include('partials/dashboard-toolbar', { record, user, isReadOnly, helpers }) %>

      <% if (flash) { %>
        <div class="alert-success" role="status" aria-live="polite"><%= flash %></div>
      <% } %>

      <% if (error) { %>
        <div class="alert-error" role="alert"><%= error %></div>
      <% } %>

      <section id="dashboard-content">
        <form id="sheet-form" action="/dashboard/save" method="post">
          <input type="hidden" id="payload-input" name="payload" />

          <%- include('partials/record-metadata-card', { record, isReadOnly }) %>

          <div class="card">
            <div class="section-title">
              <h2>Lançamento mensal</h2>
              <% if (!isReadOnly) { %>
                <button type="button" class="sheet-row-btn sheet-row-btn--add js-sheet-add-row">
                  Adicionar linha
                </button>
              <% } %>
            </div>
            <div class="sheet-table-desktop">
              <%- include('partials/tax-table-unified', { record, isReadOnly, helpers, printMode: false, embeddedInCard: true }) %>
            </div>
            <%- include('partials/tax-table-mobile-cards', { record, isReadOnly, helpers }) %>
            <%- include('partials/guias-panel', { record, helpers, printMode: false }) %>
            <%- include('partials/competency-summary', { record, helpers, printMode: false }) %>
          </div>
        </form>
      </section>
    </div>
  </div>

  <script>
    window.__DASHBOARD_STATE__ = <%- JSON.stringify({ record, isReadOnly }) %>;
  </script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
