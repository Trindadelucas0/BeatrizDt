<script>
(function () {
  try {
    var themes = ['dauto', 'claro', 'escuro'];
    var stored = localStorage.getItem('app-theme');
    var cookieMatch = document.cookie.match(/(?:^|;\s*)app-theme=([^;]+)/);
    var theme = stored || (cookieMatch && decodeURIComponent(cookieMatch[1])) || 'dauto';
    if (themes.indexOf(theme) === -1) theme = 'dauto';
    document.documentElement.dataset.theme = theme;
  } catch (e) {
    document.documentElement.dataset.theme = 'dauto';
  }
})();
</script>
