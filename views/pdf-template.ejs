<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demonstrativo <%= record.competencia %></title>
  <style><%= embeddedStyles %></style>
</head>
<body class="pdf-render-body">
  <div id="pdfArea">
    <div class="pdf-fit-outer">
      <div class="pdf-page">
        <div class="pdf-head">
          <div class="pdf-logo">
            <img src="<%= exitoLogoPath %>" alt="Êxito Contabilidade" />
          </div>
          <div class="pdf-center">
            <h2>Demonstrativo de Impostos – Folha de Pagamento</h2>
            <p>Dauto Tintas · Competência <%= record.competencia %> · Êxito Contabilidade</p>
          </div>
          <div class="pdf-logo dauto">
            <img src="<%= logoPath %>" alt="Dauto Tintas" />
          </div>
        </div>

        <div class="pdf-doc-meta">
          <span>Emitido em <b><%= emitidoEm %></b></span>
          <span>Status: <b><%= record.statusGeral || 'Em conferência' %></b></span>
          <span>Responsável: <b><%= record.responsavel || '—' %></b></span>
        </div>

        <div class="pdf-meta">
          <div><b>Competência</b><%= record.competencia %></div>
          <div><b>Data preenchimento</b><%= dataPreenchimentoLabel %></div>
          <div><b>Responsável</b><%= record.responsavel || '—' %></div>
        </div>

        <div class="pdf-box pdf-box-guias">
          <div class="pdf-box-header pdf-box-header-guias pdf-box-header-unico">
            <h3>Guias — soma Matriz + Filial</h3>
          </div>
          <%- include('partials/guias-panel', { record, helpers, printMode: true }) %>
        </div>

        <div class="pdf-box pdf-box-unico">
          <div class="pdf-box-header pdf-box-header-unico">
            <h3>Demonstrativo por empresa</h3>
          </div>
          <%- include('partials/tax-table-unified', { record, isReadOnly: true, helpers, printMode: true }) %>
        </div>

        <%- include('partials/competency-summary', { record, helpers, printMode: true }) %>

        <div class="pdf-obs">
          <b>Observações:</b><br>
          <%= record.observacoes ? record.observacoes : 'Sem observações.' %>
        </div>

        <div class="pdf-footer">
          <span class="pdf-stamp">Dauto Tintas · <%= record.competencia %></span>
          <span>Documento gerado automaticamente</span>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
